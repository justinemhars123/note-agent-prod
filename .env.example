# Required
GROQ_API_KEY=gsk_your_groq_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_public_anon_key_here

# Optional (do NOT expose service_role keys to clients)
# SUPABASE_SERVICE_KEY=your_service_role_key_here
OPENAI_API_KEY=your_openai_key_here
SENTRY_DSN=

# Server
PORT=3001
NODE_ENV=production

# Comma-separated list of allowed origins for CORS (optional)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# ───────────────────────────────────────────────────────────────────────────────
# Environment Configuration for Note-to-Action-Agent
# 
# IMPORTANT: Never commit .env files with real values!
# For development: Copy to .env.local (in .gitignore)
# For production: Set variables in GitHub Secrets or hosting platform
# ───────────────────────────────────────────────────────────────────────────────

# ─── API Keys & Secrets (REQUIRED) ────────────────────────────────────────────
# Groq AI API Configuration - Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# OpenAI API Configuration (Optional - used as fallback)
# Get your API key at: https://platform.openai.com/account/api-keys
# OPENAI_API_KEY=sk_your_api_key_here

# ─── Supabase Configuration (REQUIRED for database) ──────────────────────────
# Get from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_public_key
SUPABASE_SERVICE_KEY=your_service_role_key

# ─── Server Configuration ────────────────────────────────────────────────────
# Server port (default 3000 for development, 3001 recommended for production)
PORT=3000

# Node environment (development, test, or production)
NODE_ENV=development

# ─── Security & CORS ─────────────────────────────────────────────────────────
# Allowed frontend origins (comma-separated for multiple domains)
# Format: https://domain.com or http://localhost:3000
# IMPORTANT: Only allow your trusted frontend domains!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Error Tracking (Optional) ───────────────────────────────────────────────
# Sentry error monitoring - Get from: https://sentry.io
# This allows real-time error tracking in production
SENTRY_DSN=

# ───────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ───────────────────────────────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT:
#   1. Copy this file: cp .env.example .env.local
#   2. Edit .env.local with your actual keys
#   3. .env.local is in .gitignore (safe from git)
#   4. Run: npm run dev
#
# GITHUB CI/CD SECRETS:
#   1. Go to GitHub → Settings → Secrets and Variables → Actions
#   2. Add these secrets (only required ones):
#      - GROQ_API_KEY
#      - SUPABASE_URL
#      - SUPABASE_KEY
#   3. They're automatically injected into CI/CD pipeline
#   4. Never commit .env files to Git!
#
# PRODUCTION DEPLOYMENT (Railway/Render):
#   1. In hosting platform dashboard, add environment variables
#   2. Set these values (never use .env files in production!):
#      - PORT=3001
#      - NODE_ENV=production
#      - GROQ_API_KEY=[Your rotated key]
#      - SUPABASE_URL=[Production database]
#      - SUPABASE_KEY=[Production anon key]
#      - ALLOWED_ORIGINS=[Your production domain]
#      - SENTRY_DSN=[Optional error tracking]
#   3. Restart the service for changes to take effect
#
# ───────────────────────────────────────────────────────────────────────────────
# SECURITY NOTES
# ───────────────────────────────────────────────────────────────────────────────
#
# ✓ GROQ_API_KEY
#   - Format: gsk_* (easily recognized)
#   - Risk Level: HIGH (provides AI access)
#   - Rotation: Rotate keys regularly in Groq console
#   - Exposure: Keep in GitHub Secrets, never expose publicly
#
# ✓ SUPABASE_KEY (Public/Anon Key)
#   - Format: Long JWT token starting with eyJ...
#   - Risk Level: LOW (public by design, limited by RLS)
#   - Safe to: Expose in frontend code (it's limited by Row Level Security)
#   - Use for: Database queries from frontend via Supabase client
#
# ✓ SUPABASE_SERVICE_KEY (Service Role Key)
#   - Format: Long JWT token starting with eyJ...
#   - Risk Level: CRITICAL (has admin privileges!)
#   - Safe to: Only on backend (server.js)
#   - Use for: Admin-level database operations
#   - Never expose: In frontend code or public repositories
#
# ✓ SENTRY_DSN
#   - Format: https://abc@sentry.io/123456
#   - Risk Level: LOW (logs errors, not sensitive data)
#   - Safe to: Expose in frontend/backend code
#   - Use for: Error tracking and monitoring
#
# ───────────────────────────────────────────────────────────────────────────────
