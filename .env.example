# Groq API Configuration (Required)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# OpenAI API Configuration (Optional - used as fallback)
# Get your API key at: https://platform.openai.com/account/api-keys
# Uncomment to enable OpenAI fallback if Groq is unavailable
# OPENAI_API_KEY=sk_your_api_key_here

# Server Configuration (Optional)
# PORT=3001

# Environment (set to 'production' when deploying)
# NODE_ENV=production

# CORS — comma-separated list of allowed frontend origins
# Leave blank for localhost-only development
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
